GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json
SHEETS_DOC_ID=1xSjvbZwI-3oLScimPcpBftB2E4muLV07dt1ZOVo3N5s
SHEETS_ABA_EDICOES=Edicoes
SHEETS_ABA_ARTIGOS=Artigos_Coletados

# Envio (hoje Gmail preview — substituível depois por E-goi via lib/sender.js)
