# ─────────────────────────────────────────────────────────────
# Let's Insights — variáveis de ambiente
# Copie para .env (local) e configure como Secrets no GitHub (CI).
# NUNCA commitar o .env preenchido.
# ─────────────────────────────────────────────────────────────

# Claude API (curadoria + redação)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Gemini API (geração de imagem fallback quando artigo não tem imagem — ver lib/imagegen.js)
GEMINI_API_KEY=

# Banco de dados (SQLite commitado no repo — ver lib/db.js). Caminho opcional,
# padrão é data/newsletter.db.
SQLITE_DB_PATH=

# Envio (hoje Gmail preview — substituível depois por E-goi via lib/sender.js)
SENDER=gmail
GMAIL_USER=yagod@lets.com.br
GMAIL_APP_PASSWORD=
PREVIEW_TO=yagod@lets.com.br

# E-goi (produção futura — deixar vazio por enquanto)
EGOI_API_KEY=
EGOI_LIST_ID=
